{
  "name": "@thewhiteprotocol/evm",
  "version": "2.0.0",
  "description": "The White Protocol - EVM chain implementations (Base, Ethereum, Polygon, BSC)",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:coverage": "forge coverage",
    "deploy:base-sepolia": "NETWORK=base-sepolia forge script script/Deploy.s.sol --ffi --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast --verify",
    "deploy:ethereum-sepolia": "NETWORK=ethereum-sepolia forge script script/Deploy.s.sol --ffi --rpc-url $ETHEREUM_SEPOLIA_RPC_URL --broadcast --verify",
    "deploy:polygon-amoy": "NETWORK=polygon-amoy forge script script/Deploy.s.sol --ffi --rpc-url $POLYGON_AMOY_RPC_URL --broadcast --verify",
    "deploy:bsc-testnet": "NETWORK=bsc-testnet forge script script/Deploy.s.sol --ffi --rpc-url $BSC_TESTNET_RPC_URL --broadcast --verify",
    "deploy:bsc-mainnet": "ALLOW_MAINNET=true NETWORK=bsc-testnet forge script script/Deploy.s.sol --ffi --rpc-url $BSC_MAINNET_RPC_URL --broadcast --verify",
    "deploy:sepolia": "NETWORK=base-sepolia forge script script/Deploy.s.sol --ffi --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast --verify",
    "test:e2e:base": "tsx test/e2e-base.ts",
    "test:e2e:base:full": "NETWORK=base-sepolia tsx test/e2e-base-full.ts",
    "test:e2e:base:active": "NETWORK=base-sepolia tsx test/e2e-base-full.ts",
    "test:e2e:base:v1:legacy": "NETWORK=base-sepolia DEPLOYMENT_ARTIFACT=./deployments/base-sepolia-v1-backup.json tsx test/e2e-base-full.ts",
    "test:e2e:base:v2:full": "NETWORK=base-sepolia DEPLOYMENT_ARTIFACT=./deployments/base-sepolia-v2.json tsx test/e2e-base-full.ts",
    "test:e2e:base:repeat": "NETWORK=base-sepolia tsx test/e2e-base-full.ts && NETWORK=base-sepolia tsx test/e2e-base-full.ts",
    "test:e2e:bsc:testnet:full": "NETWORK=bsc-testnet tsx test/e2e-base-full.ts",
    "test:e2e:bsc:testnet:repeat": "NETWORK=bsc-testnet tsx test/e2e-base-full.ts && NETWORK=bsc-testnet tsx test/e2e-base-full.ts",
    "test:e2e:bnb:testnet:full": "NETWORK=bsc-testnet tsx test/e2e-base-full.ts",
    "test:e2e:bnb:testnet:repeat": "NETWORK=bsc-testnet tsx test/e2e-base-full.ts && NETWORK=bsc-testnet tsx test/e2e-base-full.ts",
    "test:e2e:ethereum:sepolia:full": "NETWORK=ethereum-sepolia tsx test/e2e-base-full.ts",
    "test:e2e:ethereum:sepolia:repeat": "NETWORK=ethereum-sepolia tsx test/e2e-base-full.ts && NETWORK=ethereum-sepolia tsx test/e2e-base-full.ts",
    "test:e2e:eth:sepolia:full": "NETWORK=ethereum-sepolia tsx test/e2e-base-full.ts",
    "test:e2e:eth:sepolia:repeat": "NETWORK=ethereum-sepolia tsx test/e2e-base-full.ts && NETWORK=ethereum-sepolia tsx test/e2e-base-full.ts",
    "test:e2e:polygon:amoy:full": "NETWORK=polygon-amoy tsx test/e2e-base-full.ts",
    "test:e2e:polygon:amoy:repeat": "NETWORK=polygon-amoy tsx test/e2e-base-full.ts && NETWORK=polygon-amoy tsx test/e2e-base-full.ts",
    "verify:base-sepolia": "echo 'Run with BASESCAN_API_KEY env var set'; forge verify-contract --chain-id 84532 --compiler-version v0.8.20+commit.a1b79de6 0x396e539bCDeAF48ab9526A13c6E688CBA69C059a WhiteProtocol --watch",
    "test:e2e:bridge:base-to-ethereum:full": "tsx test/e2e-bridge-pr010i.ts",
    "test:e2e:bridge:ethereum-to-base:full": "tsx test/e2e-bridge-ethereum-to-base.ts",
    "test:e2e:bridge:base-to-bnb:full": "tsx test/e2e-bridge-base-to-bnb.ts",
    "test:e2e:bridge:base-to-polygon:full": "tsx test/e2e-bridge-base-to-polygon.ts",
    "test:e2e:bridge:bnb-source-readiness": "tsx test/e2e-bridge-bnb-source-readiness.ts",
    "test:e2e:bridge:polygon-source-readiness": "tsx test/e2e-bridge-polygon-source-readiness.ts",
    "test:e2e:bridge:bnb-to-base:full": "tsx test/e2e-bridge-bnb-to-base.ts",
    "test:e2e:bridge:polygon-to-base:full": "tsx test/e2e-bridge-polygon-to-base.ts",
    "test:e2e:bridge:ethereum-to-bnb:full": "tsx test/e2e-bridge-ethereum-to-bnb.ts",
    "test:e2e:bridge:ethereum-to-polygon:full": "tsx test/e2e-bridge-ethereum-to-polygon.ts",
    "test:e2e:bridge:bnb-to-ethereum:full": "tsx test/e2e-bridge-bnb-to-ethereum.ts",
    "test:e2e:bridge:polygon-to-ethereum:full": "tsx test/e2e-bridge-polygon-to-ethereum.ts",
    "bridge:note-state:summary": "tsx test/helpers/bridge-note-state-cli.ts summary",
    "bridge:validate-note-state": "tsx test/helpers/bridge-note-state-cli.ts validate",
    "bridge:export-note-state": "tsx test/helpers/bridge-note-state-cli.ts export",
    "bridge:note-state:readback-check": "tsx test/helpers/bridge-note-state-cli.ts readback",
    "bridge:test-note-state": "tsx test/helpers/bridge-note-state-cli.ts self-test",
    "bridge:export-base-note-state": "tsx test/helpers/solana-to-base-destination-withdraw-cli.ts export-note-state",
    "bridge:validate-base-note-state": "tsx test/helpers/solana-to-base-destination-withdraw-cli.ts validate-note-state",
    "bridge:base-note-state:readback-check": "tsx test/helpers/solana-to-base-destination-withdraw-cli.ts readback-check",
    "bridge:preflight-base-withdraw": "tsx test/helpers/solana-to-base-destination-withdraw-cli.ts preflight",
    "bridge:base:recover-merkle-path": "tsx test/helpers/solana-to-base-destination-withdraw-cli.ts recover-merkle-path",
    "bridge:base:validate-merkle-path": "tsx test/helpers/solana-to-base-destination-withdraw-cli.ts validate-merkle-path",
    "bridge:base:simulate-withdraw": "tsx test/helpers/solana-to-base-destination-withdraw-cli.ts simulate-withdraw",
    "bridge:test-base-withdraw-prep": "tsx test/helpers/solana-to-base-destination-withdraw-cli.ts self-test"
  },
  "dependencies": {
    "@thewhiteprotocol/core": "file:../../packages/core"
  },
  "devDependencies": {
    "@layerzerolabs/lz-definitions": "^3.0.168",
    "@layerzerolabs/lz-evm-messagelib-v2": "^3.0.168",
    "@layerzerolabs/lz-evm-protocol-v2": "^3.0.168",
    "@layerzerolabs/metadata-tools": "^3.0.3",
    "@layerzerolabs/oapp-evm": "^0.4.1",
    "@layerzerolabs/test-devtools-evm-foundry": "^8.0.1",
    "@layerzerolabs/toolbox-foundry": "^0.1.13",
    "solc": "^0.8.23"
  }
}
