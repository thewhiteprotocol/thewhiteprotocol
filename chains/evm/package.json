{
  "name": "@thewhiteprotocol/evm",
  "version": "2.0.0",
  "description": "The White Protocol - EVM chain implementations (Base, Ethereum, Polygon, Polygon zkEVM)",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:coverage": "forge coverage",
    "deploy:base-sepolia": "NETWORK=base-sepolia forge script script/Deploy.s.sol --ffi --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast --verify",
    "deploy:ethereum-sepolia": "NETWORK=ethereum-sepolia forge script script/Deploy.s.sol --ffi --rpc-url $ETHEREUM_SEPOLIA_RPC_URL --broadcast --verify",
    "deploy:polygon-amoy": "NETWORK=polygon-amoy forge script script/Deploy.s.sol --ffi --rpc-url $POLYGON_AMOY_RPC_URL --broadcast --verify",
    "deploy:polygon-zkevm-cardona": "NETWORK=polygon-zkevm-cardona forge script script/Deploy.s.sol --ffi --rpc-url $POLYGON_ZKEVM_CARDONA_RPC_URL --broadcast --verify",
    "deploy:sepolia": "NETWORK=base-sepolia forge script script/Deploy.s.sol --ffi --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast --verify",
    "verify:sepolia": "forge verify-contract --chain-id 84532 --compiler-version v0.8.23+commit.f704f362"
  },
  "dependencies": {
    "@thewhiteprotocol/core": "file:../../packages/core"
  },
  "devDependencies": {
    "solc": "^0.8.23"
  }
}
