# The White Protocol — Relayer Environment Variables
# Copy to .env and fill in your values.
# 
# RPC URLs: canonical names follow networks.json. Legacy aliases are supported
# with a deprecation warning:
#   BASE_SEPOLIA_RPC_URL (canonical) <- BASE_RPC_URL (legacy alias)
#   ETHEREUM_SEPOLIA_RPC_URL (canonical) <- ETH_RPC_URL (legacy alias)
#   BSC_TESTNET_RPC_URL (canonical) <- BSC_RPC_URL (legacy alias)
#   POLYGON_AMOY_RPC_URL (canonical, no alias)

# ── Solana Devnet ──
RPC_ENDPOINT=https://api.devnet.solana.com
PROGRAM_ID=C9GAJTFVgijNzB4SWZeNKmzruzjzrZ4H6J1DpKha9GoW
POOL_CONFIG=EYjYoV3RpvmYBcUi6LVGaYUzCbEjeHxga7nE7D5GEgaS
MERKLE_TREE=2DjfHs3CYK22a4SAMSH2gt6eXRwSnBzm2f4gWvmos8sD
PENDING_BUFFER=7MzDFCdPEog6orC42jCXBz53zhqysQVq5vb5J7R1DAyw
WSOL_VAULT=629JMEcz1u4AjyahByEcQtyGF3TwDnBPY7nHhaLVB9PS
SEQUENCER_WALLET=<JSON array of Solana wallet secret key bytes>

# ── Base Sepolia ──
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_PROTOCOL_ADDRESS=0x396e539bCDeAF48ab9526A13c6E688CBA69C059a
BASE_DEPLOYER_PRIVATE_KEY=<private key for Base Sepolia tx submission>

# ── Ethereum Sepolia ──
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_PROTOCOL_ADDRESS=0x5813d68a130C451420C670F5aA4a7D68F438101A
ETH_DEPLOYER_PRIVATE_KEY=<private key for Ethereum Sepolia tx submission>

# ── BNB Chain Testnet ──
BSC_TESTNET_RPC_URL=https://bsc-testnet-rpc.publicnode.com
BSC_PROTOCOL_ADDRESS=0xE8efDE51cA7B4b0dAD84e5a7296Baac87A09029B
BSC_DEPLOYER_PRIVATE_KEY=<private key for BNB Chain Testnet tx submission>

# ── Polygon Amoy ──
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_AMOY_PROTOCOL_ADDRESS=0xE8efDE51cA7B4b0dAD84e5a7296Baac87A09029B
POLYGON_AMOY_DEPLOYER_PRIVATE_KEY=<private key for Polygon Amoy tx submission>

# ── Shared EVM fallback (optional) ──
# If a per-chain deployer key above is missing, the relayer falls back to:
# EVM_DEPLOYER_PRIVATE_KEY=<shared key>

# ── Server & Protocol ──
PORT=3000
NODE_ENV=production
FEE_BPS=50
CORS_ORIGIN=https://app.thewhiteprotocol.com

# ── Solana Relayer Registry (optional) ──
# Set to "true" to allow withdrawals when on-chain RelayerRegistry is missing.
# Only for dev/test. In production (NODE_ENV=production) this is ignored and
# the relayer always fails closed if the registry is unavailable.
# RELAYER_ALLOW_MISSING_SOLANA_REGISTRY=false
SEQUENCER_AUTH_TOKEN=<random 64-char hex for protected endpoints>

# ── Bridge Watcher / Operator API (disabled and dry-run by default) ──
BRIDGE_WATCHER_ENABLED=false
BRIDGE_WATCHER_DRY_RUN=true
BRIDGE_WATCHER_INTERVAL_MS=30000
BRIDGE_WATCHER_FINDINGS_PATH=
BRIDGE_WATCHER_MAX_FINDINGS_PER_TICK=100
BRIDGE_WATCHER_FINDING_RETENTION_DAYS=30
BRIDGE_WATCHER_AUTO_FREEZE=false
BRIDGE_WATCHER_MIN_SEVERITY_TO_FREEZE=critical
BRIDGE_WATCHER_OBSERVATION_WINDOW_HOURS=24
BRIDGE_WATCHER_OBSERVATION_REPORT_PATH=./data/bridge-watcher-observation-report.json
BRIDGE_WATCHER_OBSERVATION_LABEL=hosted-testnet-dry-run
BRIDGE_OPERATOR_API_TOKEN=<random 64-char operator token for /bridge/watcher/*>
BRIDGE_ALERT_WEBHOOK_URL=<optional webhook URL stored as a secret in hosted env>
BRIDGE_ALERT_MIN_SEVERITY=high
BRIDGE_ALERT_DRY_RUN=true
# Set true for local dry-run logging without a webhook.
BRIDGE_ALERT_LOG=false
# Optional local-only output directory for npm run watcher:smoke.
BRIDGE_WATCHER_SMOKE_STATE_DIR=
# Optional JSON override, e.g. {"base-sepolia":5,"solana-devnet":{"confirmations":40,"maxAgeSeconds":86400}}
# BRIDGE_FINALITY_OVERRIDES=
# BRIDGE_MAX_FAST_PATH_AMOUNT=
# BRIDGE_MANUAL_REVIEW_AMOUNT=

# ── Bridge Signer Custody (testnet/local only by default) ──
# local-dev uses deterministic test keys and is never production-safe.
# env-file reads testnet-only secp256k1 keys from env or a gitignored file.
# kms/hsm/mpc are placeholders in PR-011F and do not sign.
BRIDGE_SIGNER_MODE=local-dev
BRIDGE_SIGNER_KEY_FILE=
BRIDGE_SIGNER_PRIVATE_KEYS_TESTNET=<comma-separated testnet-only private keys; do not use mainnet keys>
BRIDGE_ALLOW_ENV_SIGNER_IN_PRODUCTION=false

# ── Bridge Daemon (disabled by default; paper mode before live-testnet) ──
# Modes: disabled | paper | live-testnet
BRIDGE_DAEMON_MODE=disabled
BRIDGE_ALLOW_LIVE_TESTNET_SUBMIT=false
BRIDGE_ALLOW_LOCAL_DEV_SIGNER_IN_LIVE_TESTNET=false
BRIDGE_DAEMON_INTERVAL_MS=30000
BRIDGE_DAEMON_ROUTES=base-sepolia:solana-devnet,solana-devnet:base-sepolia
BRIDGE_DAEMON_STATE_PATH=
BRIDGE_DAEMON_SCAN_LOOKBACK_BLOCKS=5000
BRIDGE_DAEMON_SCAN_FROM_BLOCK=
BRIDGE_DAEMON_SCAN_TO_BLOCK=
# Optional non-secret target map, e.g. base-sepolia=0xInbox,solana-devnet=ProgramId
BRIDGE_DAEMON_SUBMIT_TARGETS=
BRIDGE_BASE_SEPOLIA_OUTBOX_ADDRESS=
SOLANA_DEVNET_RPC_URL=
BRIDGE_SIGNER_THRESHOLD=2
BRIDGE_SIGNER_SET_VERSION=1

# ── Circuit Settings ──
WITHDRAW_VK_PATH=./circuits/build/withdraw_vk.json
WITHDRAW_V2_VK_PATH=./circuits/build/withdraw_v2_vk.json
CIRCUITS_PATH=./circuits/build
TREE_DEPTH=20
MIN_WITHDRAWAL=1000000
MAX_WITHDRAWAL=1000000000000
SUPPORTED_ASSETS=So11111111111111111111111111111111111111112

# ── Stealth Address Scanner ──
# Currently supports Solana and Base only.
# Ethereum/BNB/Polygon stealth scanner env vars are not yet wired.
STEALTH_SCANNER_POLL_INTERVAL_MS=5000
STEALTH_SCANNER_BATCH_SIZE=100
STEALTH_SOLANA_RPC_URL=https://api.devnet.solana.com
STEALTH_BASE_RPC_URL=https://sepolia.base.org
STEALTH_META_ADDRESS_VERSION=1
