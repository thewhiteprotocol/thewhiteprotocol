# The White Protocol Relayer Configuration

# Solana RPC endpoint
RPC_ENDPOINT=https://api.devnet.solana.com

# Relayer wallet keypair (JSON array of numbers)
RELAYER_KEYPAIR=[1,2,3,...]

# The White Protocol Program ID
PROGRAM_ID=C9GAJTFVgijNzB4SWZeNKmzruzjzrZ4H6J1DpKha9GoW

# Pool configuration PDA
POOL_CONFIG=EYjYoV3RpvmYBcUi6LVGaYUzCbEjeHxga7nE7D5GEgaS

# Withdraw circuit verification key path
WITHDRAW_VK_PATH=../circuits/withdraw/build/withdraw.vkey.json

# Circuits build directory
CIRCUITS_PATH=../circuits/build

# Merkle tree depth
TREE_DEPTH=20

# Relayer fee in basis points (100 = 1%)
FEE_BPS=50

# Minimum withdrawal amount (in token smallest unit)
MIN_WITHDRAWAL=1000000

# Maximum withdrawal amount (in token smallest unit)
MAX_WITHDRAWAL=1000000000000

# CORS origin — comma-separated list of allowed origins (no wildcard in production)
# CORS_ORIGIN=https://your-app.vercel.app

# Sequencer auth token — required for state-mutating API endpoints
SEQUENCER_AUTH_TOKEN=change-me-to-a-random-secret

# Supported assets (comma-separated mint addresses)
SUPPORTED_ASSETS=So11111111111111111111111111111111111111112,4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Server port
PORT=3000
