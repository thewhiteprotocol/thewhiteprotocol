{
  "name": "@thewhiteprotocol/monorepo",
  "version": "2.0.0",
  "description": "The White Protocol - Multi-chain privacy protocol monorepo (Solana + Base)",
  "private": true,
  "workspaces": [
    "packages/*",
    "chains/*/",
    "relayer/"
  ],
  "scripts": {
    "build:core": "cd packages/core && npm run build",
    "build:solana": "cd chains/solana && anchor build",
    "build:relayer": "cd relayer && npm run build",
    "build:marketing": "cd frontend && npm run build:client",
    "build:app": "npm run build:core && cd app && npm run build",
    "test:solana": "cd chains/solana && npm test",
    "test:e2e:solana": "cd chains/solana && npx tsx tests/run-all-e2e.ts",
    "test:base": "cd chains/base && forge test",
    "relayer:start": "cd relayer && npm start",
    "dev:site": "cd frontend && npm run dev",
    "dev:app": "cd app && npm run dev",
    "dev:relayer": "cd relayer && npm start",
    "dev": "concurrently \"npm run dev:site\" \"npm run dev:app\" \"npm run dev:relayer\" ",
    "download:circuits": "node tools/download-circuits.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thewhiteprotocol/thewhiteprotocol"
  },
  "keywords": [
    "privacy",
    "zk",
    "zero-knowledge",
    "solana",
    "base",
    "ethereum",
    "defi"
  ],
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "bfj": "^9.1.3",
    "underscore": "^1.13.8"
  },
  "license": "MIT"
}
